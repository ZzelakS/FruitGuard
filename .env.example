# ─── JWT Auth ──────────────────────────────────────────────────────
JWT_SECRET=fruitguard-super-secret-jwt-key-2025
ADMIN_EMAIL=admin@fruitguard.com
ADMIN_PASSWORD=FruitGuard@2025

# ─── Firebase ──────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Firebase Storage Rules (set in Firebase Console) ──────────────
# Enable Firebase Storage in your project, then set these rules:
#
# rules_version = '2';
# service firebase.storage {
#   match /b/{bucket}/o {
#     match /products/{allPaths=**} {
#       allow read: if true;
#       allow write: if request.auth != null;  // or: if true; for dev
#     }
#   }
# }
#
# For development, you can temporarily use:
#   allow read, write: if true;
# (remember to tighten rules before going live)
